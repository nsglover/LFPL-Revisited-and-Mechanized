% Code Listing Settings
\lstset
{
  numbers=none, numberstyle=\tiny, stepnumber=1, numbersep=5pt,
  basicstyle=\tt\small, escapechar=\%, mathescape,
  columns=flexible, xleftmargin=\leftmargini,
  morekeywords={mod,div,matchD},
  literate={-o}{$\multimap$ }{3} {*}{$\otimes$ }{2} {=>}{$\Rightarrow$ }{3} {diam}{$\lozenge$ }{2},
  firstnumber=auto
}



% Code and Judgement Fonts

\newcommand{\listing}[1]{\lstinline[breaklines,columns=fullflexible]!#1!}
\newcommand{\code}[1]{\ensuremath{\mathtt{#1}}}
\newcommand{\jmt}[1]{\ensuremath{\mathsf{#1}}}



% Syntax Display and Environment

\NewDocumentCommand{\syn}{m m m}{\mathop{\IfBooleanTF{#1}{#3}{#2}}\nolimits}

\newenvironment{syntax}[2]
{
  \begin{displaymath}
  \begin{array}{rll}
  \mathsf{#1} & #2 \quad & ::=
}
{
  \end{array}
  \end{displaymath}
}

\newcommand{\sitem}[2]{\ensuremath{\\ | & #1 & \text{#2}}}
\newcommand{\newsort}[2]{\ensuremath{\\ \mathsf{#1} & #2 & ::=}}